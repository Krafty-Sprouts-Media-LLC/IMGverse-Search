# =============================================================================
# .env.example
# IMGverse Search — all environment variables documented.
# Copy to .env for local dev; in Dokploy paste into the Environment tab.
#
# @package IMGverse-Search
# @since   1.0.0
# =============================================================================

# ---------------------------------------------------------------------------
# Stack identity — used to name Docker volumes.
# Set BEFORE first deploy. Short slug recommended: e.g. "imgverse"
# produces volumes named imgverse_redis_data
# ---------------------------------------------------------------------------
STACK_SLUG=imgverse

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
PORT=3000

# ---------------------------------------------------------------------------
# API Keys — leave blank to skip that provider automatically.
# Openverse: optional OAuth (required on many VPS/datacenter hosts — see README).
# iNaturalist requires no key.
# ---------------------------------------------------------------------------
OPENVERSE_CLIENT_ID=
OPENVERSE_CLIENT_SECRET=
UNSPLASH_KEY=
PEXELS_KEY=
PIXABAY_KEY=

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_URL=redis://redis:6379
REDIS_MAXMEMORY=256mb
REDIS_MAXMEMORY_POLICY=allkeys-lru

# ---------------------------------------------------------------------------
# Proxy security
# ---------------------------------------------------------------------------
PROXY_MAX_SIZE_MB=20

# ---------------------------------------------------------------------------
# Resource limits (optional overrides)
# ---------------------------------------------------------------------------
NGINX_CPU_LIMIT=0.5
NGINX_MEMORY_LIMIT=128M
APP_CPU_LIMIT=1.0
APP_MEMORY_LIMIT=512M
REDIS_CPU_LIMIT=0.25
REDIS_MEMORY_LIMIT=256M
